{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AiNIR Trust Receipt",
  "type": "object",
  "required": [
    "canonical_draft_sha256",
    "draft_hash",
    "evidence_summary",
    "gate_results",
    "production_runtime_ready",
    "raw_source_sha256",
    "receipt_id",
    "receipt_kind",
    "registry_snapshot",
    "registry_snapshot_hash",
    "safety_registry_hash",
    "stable_receipt_projection_hash",
    "status",
    "trusted_context",
    "v1_final_ready",
    "verifier_report_hash",
    "version"
  ],
  "properties": {
    "receipt_id": {
      "type": "string"
    },
    "receipt_kind": {
      "const": "AiNIRTrustReceipt"
    },
    "version": {
      "type": "string"
    },
    "generated_at": {
      "type": "string"
    },
    "status": {
      "enum": [
        "passed",
        "refused",
        "invalid",
        "hold"
      ]
    },
    "module_id": {
      "type": "string"
    },
    "workflow": {
      "type": "string"
    },
    "draft_hash": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "safety_registry_hash": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "verifier_report_hash": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "trusted_context": {
      "type": "object"
    },
    "failed_gates": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "warning_gates": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "lowering_eligibility": {
      "type": "object"
    },
    "production_runtime_ready": {
      "const": false
    },
    "v1_final_ready": {
      "const": false
    },
    "external_consumer_handoff": {
      "type": "object"
    },
    "canonical_draft_sha256": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "raw_source_sha256": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "evidence_summary": {
      "type": "object"
    },
    "stable_receipt_projection_hash": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "gate_results": {
      "type": "object"
    },
    "registry_snapshot_hash": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "registry_snapshot": {
      "type": "object"
    }
  }
}